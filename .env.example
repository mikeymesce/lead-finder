# Google Sheets (optional — results also save to leads.csv)
GOOGLE_SHEET_ID=your-sheet-id-here

# Gmail email digest (optional — set up an App Password, not your regular password)
# Instructions: myaccount.google.com > Security > 2-Step Verification > App passwords
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=your-app-password-here
